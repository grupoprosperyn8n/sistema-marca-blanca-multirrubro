# Supabase - Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env a GitHub.

# Project URL (obtenida de Supabase Dashboard > Settings > API)
# ⚠️ PRIVADA - expone la ubicación de tu proyecto
NEXT_PUBLIC_SUPABASE_URL=your_project_url

# Anon Key (pública, se usa en frontend con RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Service Role Key (PRIVADA - solo para backend/n8n/Edge Functions)
# ⚠️ NUNCA en frontend, NUNCA visible en logs, permisos TOTALES sobre DB
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Project Reference (ID del proyecto, ej: abcdefghijkl)
SUPABASE_PROJECT_REF=your_project_ref

# DB Password (para migraciones directas)
SUPABASE_DB_PASSWORD=your_db_password

# Database URL (opcional, para migraciones directas vía psql)
DATABASE_URL=postgresql://postgres:${SUPABASE_DB_PASSWORD}@db.${SUPABASE_PROJECT_REF}.supabase.co:5432/postgres

# --- Legado / Alias (compatibilidad hacia atrás) ---
# Si ves SUPABASE_URL, SUPABASE_ANON_KEY o SUPABASE_SERVICE_KEY,
# ahora se llaman NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
# y SUPABASE_SERVICE_ROLE_KEY respectivamente.
