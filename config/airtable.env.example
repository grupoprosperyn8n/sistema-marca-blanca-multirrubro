# Airtable - Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env a GitHub.

# Personal Access Token (generado en https://airtable.com/create/tokens)
# Permisos mínimos necesarios: data.records:read, data.records:write
# ⚠️ API key sensible. No exponer públicamente ni comitear con valor real.
AIRTABLE_API_KEY=your_airtable_token

# Base ID (obtenido de la URL de la base: https://airtable.com/[baseId])
AIRTABLE_BASE_ID=your_base_id

# Table names (opcional, se pueden definir en cada script/workflow)
# AIRTABLE_TABLE_CLIENTES=Clientes
# AIRTABLE_TABLE_PRODUCTOS=Productos
# AIRTABLE_TABLE_PEDIDOS=Pedidos

# --- Legado / Alias ---
# Si ves AIRTABLE_TOKEN, ahora se llama AIRTABLE_API_KEY.
