# n8n - Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env a GitHub.

# n8n instance URL (URL completa, ej: http://localhost:5678 o https://n8n.tudominio.com)
# ⚠️ API key sensible. No exponer públicamente ni comitear con valor real.
N8N_BASE_URL=http://localhost:5678

# n8n API Key (generada en Settings > API)
N8N_API_KEY=your_n8n_api_key

# n8n Webhook Secret (para validar webhooks entrantes)
N8N_WEBHOOK_SECRET=your_webhook_secret

# --- Credenciales para conexiones internas (n8n las usa como variables) ---
# Estas NO son variables de entorno del sistema, sino valores que n8n inyecta
# en los workflows mediante su sistema de credenciales.
# Vé: config/supabase.env.example y config/airtable.env.example

# --- Legado / Alias ---
# Si ves N8N_HOST, N8N_PORT, N8N_PROTOCOL o N8N_URL, ahora se usa N8N_BASE_URL.
# N8N_URL se derivaba como ${N8N_PROTOCOL}://${N8N_HOST}:${N8N_PORT}
# Ahora es un solo valor directo: N8N_BASE_URL
