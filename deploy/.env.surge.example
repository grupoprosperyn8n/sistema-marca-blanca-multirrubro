# .env.surge — Credenciales para deploy a Surge.sh
# Copiá este archivo a deploy/.env.surge y completá los valores.
# NO commitees .env.surge (ya está en .gitignore).
#
# Cómo obtener SURGE_TOKEN:
#   1. Asegurate de tener surge CLI instalado: npm install -g surge
#   2. Logueate: surge login
#   3. Obtené el token: surge token
#   4. Copiá el token acá

SURGE_LOGIN=streethead01@gmail.com
SURGE_TOKEN=token_del_usuario_aqui
