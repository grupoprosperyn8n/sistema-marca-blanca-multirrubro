{
  "name": "Airtable Proxy",
  "nodes": [
    {
      "id": "webhook-001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "path": "airtable-proxy",
        "options": {}
      }
    },
    {
      "id": "http-001",
      "name": "HTTP Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 300],
      "parameters": {
        "url": "={{ 'https://api.airtable.com/v0/app93Vhy56KrxNhwe/' + $('Webhook').item.json.query.tablePath + ($('Webhook').item.json.query.recordId ? '/' + $('Webhook').item.json.query.recordId : '') }}",
        "options": {
          "queryParameters": {
            "parameters": [
              {"name": "maxRecords", "value": "={{ $('Webhook').item.json.query.maxRecords }}"},
              {"name": "filterByFormula", "value": "={{ $('Webhook').item.json.query.filterByFormula }}"},
              {"name": "view", "value": "={{ $('Webhook').item.json.query.view }}"},
              {"name": "offset", "value": "={{ $('Webhook').item.json.query.offset }}"}
            ]
          }
        },
        "sendQuery": true,
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.AIRTABLE_TOKEN_PROYECTO }}"
            }
          ]
        }
      }
    }
  ],
  "connections": {
    "webhook-001": {
      "main": [
        [
          {
            "node": "HTTP Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
